<Window x:Class="Proiect_MSOA___nr_5.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Barber Shop - Portal Client" Height="680" Width="950"
        WindowStartupLocation="CenterScreen" Background="#121212">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1E1E1E" CornerRadius="5" Grid.Row="0" Margin="0,0,0,10" Padding="10,5">
            <Grid>
                <TextBlock FontWeight="Bold" Foreground="#D4AF37" Text="💈 Barber Shop Portal" VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Foreground="Gray" Text="👤 Conectat ca: " VerticalAlignment="Center"/>
                    <TextBlock FontWeight="SemiBold" Foreground="LightGreen" Text="andrei (Profil Client Activ)" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Background="#1E1E1E" BorderThickness="0" Grid.Row="1">
            <TabItem FontSize="13" FontWeight="Bold" Header="🛒 Catalog si Rezervari Noi" Height="30" Width="180">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#D4AF37" Margin="0,0,0,5" Text="💈 Servicii și Produse Disponibile"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="13" Foreground="White" Margin="0,0,5,0" Text="🔍 Căutare rapidă: " VerticalAlignment="Center"/>
                            <TextBox Background="#2D2D2D" BorderBrush="Gray" Foreground="White" Grid.Column="1" Height="25" Padding="3,0,0,0" TextChanged="TxtCautare_TextChanged" x:Name="txtCautare"/>
                        </Grid>

                        <DataGrid AlternatingRowBackground="#353535" AutoGenerateColumns="False" Background="#1E1E1E" BorderThickness="0" Foreground="White" Height="340" IsReadOnly="True" RowBackground="#2D2D2D" x:Name="dgCatalogClient">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Denumire}" Header="Denumire" Width="2*"/>
                                <DataGridTextColumn Binding="{Binding Pret}" Header="Preț (Lei)" Width="1*"/>
                                <DataGridTextColumn Binding="{Binding Tip}" Header="Tip" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Background="#2E7D32" BorderBrush="Transparent" Click="BtnCumparaProdus_Click" Content="🛍️ Cumpără Produsul Selectat (Livrare Rapidă)" FontWeight="Bold" Foreground="White" Height="35" Margin="0,15,0,0"/>
                    </StackPanel>

                    <Border Background="#252525" CornerRadius="10" Grid.Column="1" Height="380" Margin="15,30,0,0" Padding="20" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15" Text="📅 Solicită o Programare Nouă"/>
                            <TextBlock Foreground="#888888" Margin="0,5,0,5" Text="Alege Serviciul dorit:"/>
                            <ComboBox Height="30" Margin="0,0,0,15" x:Name="cbServiciiClient"/>
                            <TextBlock Foreground="#888888" Margin="0,5,0,5" Text="Selectează Data și Ora:"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker Grid.Column="0" Height="28" x:Name="dpData"/>
                                <ComboBox Grid.Column="1" Height="28" Margin="5,0,0,0" x:Name="cbOra">
                                    <ComboBoxItem Content="09:00"/>
                                    <ComboBoxItem Content="10:00"/>
                                    <ComboBoxItem Content="11:00"/>
                                    <ComboBoxItem Content="12:00"/>
                                    <ComboBoxItem Content="14:00"/>
                                    <ComboBoxItem Content="15:00"/>
                                    <ComboBoxItem Content="16:00"/>
                                    <ComboBoxItem Content="17:00"/>
                                </ComboBox>
                            </Grid>
                            <Button Background="#D4AF37" BorderBrush="Transparent" Click="BtnRezerva_Click" Content="🚀 Trimite Rezervarea" FontWeight="Bold" Foreground="Black" Height="35" Margin="0,35,0,10"/>
                            <Button Background="#CF6679" BorderBrush="Transparent" Click="BtnLogout_Click" Content="🚪 Deconectare" FontWeight="SemiBold" Foreground="Black" Height="30" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem FontSize="13" FontWeight="Bold" Header="📋 Istoricul si Statusul Meu" Height="30" Width="180">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14" FontWeight="Bold" Foreground="#D4AF37" Grid.Row="0" Margin="0,0,0,5" Text="📋 Fișa Ta personală: Activități și Comenzi active"/>

                    <DataGrid AlternatingRowBackground="#353535" AutoGenerateColumns="False" Background="#1E1E1E" BorderThickness="0" Foreground="White" Grid.Row="1" IsReadOnly="True" Margin="0,0,0,10" RowBackground="#2D2D2D" x:Name="dgIstoricClient">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="50"/>
                            <DataGridTextColumn Binding="{Binding IdServiciu}" Header="Cod Articol" Width="90"/>
                            <DataGridTextColumn Binding="{Binding DataOra}" Header="Data" Width="120"/>
                            <DataGridTextColumn Binding="{Binding Status}" Header="Status Curent" Width="140"/>
                            <DataGridTextColumn Binding="{Binding ObservatiiRapide}" Header="Detalii Operative / Livrare" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock FontSize="14" FontWeight="Bold" Foreground="#00838F" Grid.Row="2" Margin="0,10,0,5" Text="💬 Mesaje și Notificări Primite de la Staff (Chat Live)"/>

                    <DataGrid AlternatingRowBackground="#353535" AutoGenerateColumns="False" Background="#1E1E1E" BorderThickness="0" Foreground="White" Grid.Row="3" IsReadOnly="True" RowBackground="#2D2D2D" x:Name="dgMesajeClient">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Expeditor}" Header="Expeditor" Width="150"/>
                            <DataGridTextColumn Binding="{Binding TextMesaj}" Header="Mesaj Primit" Width="2*"/>
                            <DataGridTextColumn Binding="{Binding DataTrimitere}" Header="Data" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#252525" CornerRadius="5" Grid.Row="4" Margin="0,10,0,0" Padding="8">
                        <TextBlock FontSize="11" FontStyle="Italic" Foreground="LightGray" Text="💡 Info Livrare: Produsele cu statusul 'În așteptare livrare' sunt predate curierului în fiecare zi lucrătoare la ora 16:00." TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>