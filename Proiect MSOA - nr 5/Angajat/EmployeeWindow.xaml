<Window x:Class="Proiect_MSOA___nr_5.EmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Barber Shop - Panou Operativ Angajat" Height="530" Width="850"
        WindowStartupLocation="CenterScreen" Background="#121212">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="5" Padding="10,5" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="⚙️ Panou Securizat Staff" Foreground="#D4AF37" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="👤 Conectat ca: " Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Text="ionut (Membru Staff / Barber)" Foreground="#1976D2" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="💈 Panou de Lucru Angajat (Staff Flow)" FontSize="20" FontWeight="Bold" Foreground="#D4AF37"/>
            <TextBlock Text="Gestionează rezervările primite de la clienți și validează decontarea serviciilor efectuate:" FontSize="13" Foreground="Gray" Margin="0,2,0,0"/>
        </StackPanel>

        <DataGrid x:Name="dgProgramariAngajat" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#1E1E1E" RowBackground="#2D2D2D" AlternatingRowBackground="#353535" Foreground="White" BorderThickness="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Rezervare" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="ID Client" Binding="{Binding IdClient}" Width="1*"/>
                <DataGridTextColumn Header="ID Serviciu Solicitat" Binding="{Binding IdServiciu}" Width="1.3*"/>
                <DataGridTextColumn Header="Data si Ora" Binding="{Binding DataOra}" Width="1.5*"/>
                <DataGridTextColumn Header="Status Operational" Binding="{Binding Status}" Width="1.3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="🚪 Deconectare" Grid.Column="0" Width="130" Height="40" Background="#CF6679" Foreground="Black" FontWeight="Bold" BorderBrush="Transparent" Click="BtnLogout_Click"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="💬 Trimite Mesaj Client" Width="170" Height="40" Margin="0,0,10,0" Background="#00838F" Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Click="BtnTrimiteMesaj_Click"/>
                <Button Content="✅ Confirmă" Width="130" Height="40" Margin="0,0,10,0" Background="#1976D2" Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Click="BtnConfirma_Click"/>
                <Button Content="💰 Finalizează &amp; Încasează" Width="175" Height="40" Background="#2E7D32" Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Click="BtnFinalizeaza_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>