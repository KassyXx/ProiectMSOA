<Window x:Class="Proiect_MSOA___nr_5.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proiect_MSOA___nr_5"
        mc:Ignorable="d"
        Title="Barber Shop - Panou Administrator" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#121212">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1E1E1E" Grid.Column="0" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0">
            <Grid Margin="15,20,15,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="B  |  S" FontSize="24" FontWeight="Light" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="ADMIN PANEL" FontSize="14" FontWeight="Black" Foreground="#D4AF37" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="btnProgramari" Content="📅  Programări" Height="40" Background="#2D2D2D" Foreground="White" BorderBrush="Transparent" HorizontalContentAlignment="Left" Padding="15,0,0,0" FontWeight="SemiBold" Click="BtnProgramari_Click"/>
                    <Button x:Name="btnUtilizatori" Content="👥  Utilizatori / Clienți" Height="40" Background="Transparent" Foreground="#BBBBBB" BorderBrush="Transparent" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnUtilizatori_Click"/>
                    <Button x:Name="btnProduse" Content="💈  Produse &amp; Servicii" Height="40" Background="Transparent" Foreground="#BBBBBB" BorderBrush="Transparent" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnProduse_Click"/>
                    <Button x:Name="btnPlati" Content="💳  Plăți &amp; Încasări" Height="40" Background="Transparent" Foreground="#BBBBBB" BorderBrush="Transparent" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnPlati_Click"/>
                    <Button x:Name="btnRapoarte" Content="📊  Rapoarte Profit" Height="40" Background="Transparent" Foreground="#BBBBBB" BorderBrush="Transparent" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnRapoarte_Click"/>
                </StackPanel>

                <Button Grid.Row="2" Content="🚪 Deconectare" Height="35" Background="#CF6679" Foreground="Black" FontWeight="Bold" BorderBrush="Transparent" Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Bine ai revenit, Administrator!" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Iată situația curentă a salonului tău astăzi:" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
            </StackPanel>

            <ContentControl x:Name="ZonaCentrala" Grid.Row="1">
                <Border Background="#1E1E1E" CornerRadius="10" Padding="15">
                    <Grid>
                        <TextBlock Text="Selectează o opțiune din meniul din stânga pentru a gestiona baza de date." 
                                   Foreground="#888888" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontStyle="Italic"/>
                    </Grid>
                </Border>
            </ContentControl>
        </Grid>
    </Grid>
</Window>